# Client-only (Vite) env vars. Copy to client/.env.local to override.

# Where the default VRM is loaded from (served out of client/public).
VITE_DEFAULT_MODEL_URL=/models/nova.vrm

# Optional: absolute API base for the deployed server. Leave empty in dev — the
# Vite dev server proxies /api to the local server automatically.
VITE_API_BASE=
